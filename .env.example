# ─── Database ────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (pooled recommended for serverless)
REM_DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require

# ─── Solana ───────────────────────────────────────────────────────────────────
# RPC endpoint — use a provider (Helius, QuickNode, Alchemy) or the public devnet
SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Base58-encoded private key of the wallet that has mint authority over USX
# Generate with: solana-keygen new --no-bip39-passphrase --outfile /tmp/mint-auth.json
# Then encode:   cat /tmp/mint-auth.json | node -e "const bs58=require('bs58');const k=JSON.parse(require('fs').readFileSync('/dev/stdin','utf8'));console.log(bs58.encode(Buffer.from(k)))"
MOCK_USX_MINT_AUTHORITY_KEY=<base58-encoded-private-key>

# Public key of the operator wallet (used for display / ATA derivation)
MOCK_USX_OPERATOR_PUBLIC_KEY=<base58-encoded-public-key>
MOCK_BANK_MINT_ADDRESS=<base58-encoded-public-key>